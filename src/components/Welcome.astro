---
import astroLogo from '../assets/astro.svg';
import background from '../assets/background.svg';
---

<main class="relative z-10 w-full min-h-screen flex items-center justify-center p-8">
	<div class="text-center text-[#00ffff] max-w-2xl">
		<h1 class="text-5xl md:text-6xl font-bold mb-4 drop-shadow-lg leading-tight select-none">
			Bienvenido a mi Portfolio
		</h1>
		<p class="text-xl md:text-2xl mb-8 opacity-90 drop-shadow-md select-none">
			Desarrollador Full Stack
		</p>
		<div class="mb-12">
			<p class="text-lg opacity-80 drop-shadow-md select-none">
				Especializado en tecnologías modernas y diseño creativo
			</p>
		</div>
		<div class="flex gap-4 justify-center flex-wrap">
			<button class="px-8 py-3 bg-white/20 text-white border-2 border-white/30 rounded-lg font-semibold backdrop-blur-md hover:bg-white/30 hover:border-white/50 hover:-translate-y-1 transition-all duration-300">
				Ver Proyectos
			</button>
			<button class="px-8 py-3 bg-transparent text-white border-2 border-white/50 rounded-lg font-semibold hover:bg-white/10 hover:-translate-y-1 transition-all duration-300">
				Contacto
			</button>
		</div>
	</div>
</main>
