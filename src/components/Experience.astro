---
---

<section class="relative z-10 w-full min-h-screen flex items-center justify-center p-8">
	<div class="text-center text-white max-w-4xl">
		<h2 class="text-4xl md:text-5xl font-bold mb-8 drop-shadow-lg">
			Mis Habilidades
		</h2>
		
		<div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
			<div class="skill-category">
				<h3 class="text-2xl font-semibold mb-4 drop-shadow-md">Frontend</h3>
				<ul class="space-y-2">
					<li class="skill-item">HTML5 & CSS3</li>
					<li class="skill-item">JavaScript / TypeScript</li>
					<li class="skill-item">React</li>
					<li class="skill-item">Vue.js</li>
					<li class="skill-item">Astro</li>
					<li class="skill-item">Tailwind CSS</li>
				</ul>
			</div>
			
			<div class="skill-category">
				<h3 class="text-2xl font-semibold mb-4 drop-shadow-md">Backend</h3>
				<ul class="space-y-2">
					<li class="skill-item">Node.js</li>
					<li class="skill-item">Express</li>
					<li class="skill-item">Python</li>
					<li class="skill-item">Django</li>
					<li class="skill-item">RESTful APIs</li>
					<li class="skill-item">GraphQL</li>
				</ul>
			</div>
			
			<div class="skill-category">
				<h3 class="text-2xl font-semibold mb-4 drop-shadow-md">Herramientas & Otros</h3>
				<ul class="space-y-2">
					<li class="skill-item">Git & GitHub</li>
					<li class="skill-item">Docker</li>
					<li class="skill-item">MongoDB</li>
					<li class="skill-item">PostgreSQL</li>
					<li class="skill-item">AWS</li>
					<li class="skill-item">CI/CD</li>
				</ul>
			</div>
		</div>
		
		<div class="mt-8">
			<p class="text-lg opacity-80 drop-shadow-md">
				Constantemente aprendiendo y mejorando mis habilidades para crear soluciones modernas y eficientes.
			</p>
		</div>
	</div>
</section>

<style>
.skill-category {
	background-color: rgba(255, 255, 255, 0.1);
	border-radius: 0.75rem;
	padding: 1.5rem;
	border: 1px solid rgba(255, 255, 255, 0.2);
	backdrop-filter: blur(10px);
	transition: all 0.3s ease;
}

.skill-category:hover {
	background-color: rgba(255, 255, 255, 0.15);
	transform: translateY(-5px);
	box-shadow: 0 10px 20px rgba(0, 0, 0, 0.2);
}

.skill-item {
	padding: 0.5rem 0;
	transition: all 0.2s ease;
}

.skill-item:hover {
	transform: translateX(5px);
	color: rgba(255, 255, 255, 1);
}
</style>