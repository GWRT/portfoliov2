<canvas id="galaxy-canvas"></canvas>

<script>
    import { prepareWithSegments, layoutWithLines, walkLineRanges } from "@chenglou/pretext";

    const RAMP = " .·:;+=xX$&@#";
    const FONT_SIZE = 11;
    const FONT = `${FONT_SIZE}px "Courier New", monospace`;
    const LINE_H = 15;

    const el = document.getElementById("galaxy-canvas") as HTMLCanvasElement;
    const ctx = el.getContext("2d")!;

    const px = document.createElement("canvas");
    const pxCtx = px.getContext("2d")!;

    const _samp = prepareWithSegments("X".repeat(100), FONT, { whiteSpace: "pre-wrap" });
    let CW = FONT_SIZE * 0.601;
    walkLineRanges(_samp, 99999, (line) => {
        CW = line.width / 100;
    });

    let img: HTMLImageElement | null = null;
    let raf = 0;

    let angle = 0;
    const ROTATE_SPD = 0.00025;
    let breath = 0;
    const BREATH_SPD = 0.004;
    const BREATH_AMP = 0.055;
    const TWINKLE_DENS = 0.003;

    let viewScale = 1.0;
    const S_MIN = 0.35;
    const S_MAX = 3.2;
    let panX = 0;
    let panY = 0;

    let dragging = false;
    let mx0 = 0,
        my0 = 0;

    //colores
    function amberColor(bri: number): string {
        const t = bri / 255;
        if (t < 0.35) {
            const u = t / 0.35;
            const r = Math.round(80 + (255 - 80) * u);
            const g = Math.round(20 + (124 - 20) * u);
            const b = Math.round(0);
            return `rgb(${r},${g},${b})`;
        } else if (t < 0.68) {
            const u = (t - 0.35) / 0.33;
            const r = 255;
            const g = Math.round(124 + (171 - 124) * u);
            const b = 0;
            return `rgb(${r},${g},${b})`;
        } else {
            const u = (t - 0.68) / 0.32;
            const r = 255;
            const g = Math.round(171 + (255 - 171) * u);
            const b = Math.round(102 * u);
            return `rgb(${r},${g},${b})`;
        }
    }

    // estrellas
    const STAR_COUNT = 160;
    interface Star {
        col: number;
        row: number;
        phase: number;
        spd: number;
        ch: string;
    }
    let bgStars: Star[] = [];
    let lastCols = 0,
        lastRows = 0;

    function initStars(cols: number, rows: number) {
        bgStars = [];
        const chars = [".", "·", ".", "·", "+", "*", "."];
        for (let i = 0; i < STAR_COUNT; i++) {
            bgStars.push({
                col: Math.random() * cols,
                row: Math.random() * rows,
                phase: Math.random() * Math.PI * 2,
                spd: 0.012 + Math.random() * 0.038,
                ch: chars[Math.floor(Math.random() * chars.length)],
            });
        }
    }

    // Estrella hacia el centro del ajugero
    interface AbsorbStar {
        r: number;
        theta: number;
        trail: Array<{ c: number; r: number; frac: number }>;
        done: boolean;
        wait: number;
    }

    let absorb: AbsorbStar = spawnAbsorb();

    function spawnAbsorb(): AbsorbStar {
        return {
            r: 0.4 + Math.random() * 0.14,
            theta: Math.random() * Math.PI * 2,
            trail: [],
            done: false,
            wait: 0,
        };
    }

    function stepAbsorb(cols: number, rows: number) {
        if (absorb.done) {
            absorb.wait--;
            if (absorb.wait <= 0) absorb = spawnAbsorb();
            return;
        }

        const cx = cols / 2 + panX / CW;
        const cy = rows / 2 + panY / LINE_H;
        const maxR = Math.sqrt((cols * CW) ** 2 + (rows * LINE_H) ** 2) / 2;
        const pixR = absorb.r * maxR;
        const col = Math.round(cx + (Math.cos(absorb.theta) * pixR) / CW);
        const row = Math.round(cy + (Math.sin(absorb.theta) * pixR) / LINE_H);

        absorb.trail.unshift({ c: col, r: row, frac: absorb.r });
        if (absorb.trail.length > 16) absorb.trail.pop();

        const angSpeed = 0.02 + (0.55 - absorb.r) * 0.1;
        absorb.theta += angSpeed;
        absorb.r -= 0.0035;

        if (absorb.r < 0.022) {
            absorb.done = true;
            absorb.trail = [];
            absorb.wait = 200 + Math.floor(Math.random() * 240);
        }
    }

    function charOf(b: number) {
        return RAMP[Math.floor((b / 255) * (RAMP.length - 1))];
    }

    function resize() {
        el.width = window.innerWidth;
        el.height = window.innerHeight;
    }

    function renderFrame() {
        const W = el.width;
        const H = el.height;
        const cols = Math.ceil(W / CW);
        const rows = Math.ceil(H / LINE_H);

        if (px.width !== cols || px.height !== rows) {
            px.width = cols;
            px.height = rows;
        }

        if (lastCols !== cols || lastRows !== rows) {
            initStars(cols, rows);
            lastCols = cols;
            lastRows = rows;
        }

        if (img) {
            breath += BREATH_SPD;
            const s = viewScale * (1 + Math.sin(breath) * BREATH_AMP);

            pxCtx.clearRect(0, 0, cols, rows);
            pxCtx.save();
            pxCtx.translate(cols / 2 + panX / CW, rows / 2 + panY / LINE_H);
            pxCtx.rotate(angle);
            const sz = Math.max(cols, rows) * 0.85 * s;
            const ar = img.naturalWidth / (img.naturalHeight || 1);
            pxCtx.drawImage(img, (-sz * ar) / 2, -sz / 2, sz * ar, sz);
            pxCtx.restore();
            angle += ROTATE_SPD;
        }

        const { data } = pxCtx.getImageData(0, 0, cols, rows);

        // ASCII grid
        const asciiRows: string[] = new Array(rows);
        for (let r = 0; r < rows; r++) {
            let line = "";
            for (let c = 0; c < cols; c++) {
                const i4 = (r * cols + c) * 4;
                const bri = 0.299 * data[i4] + 0.587 * data[i4 + 1] + 0.114 * data[i4 + 2];
                const twk = Math.random() < TWINKLE_DENS ? 80 : 0;
                line += charOf(Math.min(bri + twk, 255));
            }
            asciiRows[r] = line;
        }

        const prepared = prepareWithSegments(asciiRows.join("\n"), FONT, { whiteSpace: "pre-wrap" });
        const { lines } = layoutWithLines(prepared, cols * CW + CW, LINE_H);

        ctx.fillStyle = "#000";
        ctx.fillRect(0, 0, W, H);
        ctx.font = FONT;
        ctx.textBaseline = "top";

        // Galaxy ASCII - paleta
        for (let i = 0; i < lines.length && i < rows; i++) {
            const txt = lines[i].text;
            const y = i * LINE_H;
            for (let j = 0; j < txt.length && j < cols; j++) {
                if (txt[j] === " ") continue;
                const i4 = (i * cols + j) * 4;
                const bri = 0.299 * data[i4] + 0.587 * data[i4 + 1] + 0.114 * data[i4 + 2];
                if (bri < 4) continue;
                ctx.fillStyle = amberColor(bri);
                ctx.fillText(txt[j], j * CW, y);
            }
        }

        // fondo estrellas
        const now = performance.now() * 0.001;
        for (const star of bgStars) {
            const lum = 0.4 + 0.6 * Math.sin(star.phase + now * star.spd);
            if (lum < 0.3) continue;
            ctx.fillStyle = lum > 0.72 ? `rgba(255,209,102,${lum.toFixed(2)})` : `rgba(255,171,0,${lum.toFixed(2)})`;
            ctx.fillText(star.ch, Math.floor(star.col) * CW, Math.floor(star.row) * LINE_H);
        }

        // estrella siendo absorbida por el agujero
        stepAbsorb(cols, rows);
        if (!absorb.done && absorb.trail.length > 0) {
            const trailChars = ["*", "+", "x", ";", ":", ".", "·", " "];
            for (let t = 0; t < absorb.trail.length; t++) {
                const pt = absorb.trail[t];
                if (pt.c < 0 || pt.c >= cols || pt.r < 0 || pt.r >= rows) continue;
                const age = t / absorb.trail.length;
                const alpha = ((1 - age) * Math.min(pt.frac * 2.2, 1) * 0.95).toFixed(2);
                const ch = trailChars[Math.min(t, trailChars.length - 1)];
                if (t === 0) {
                    ctx.fillStyle = `rgba(255,255,230,${alpha})`;
                } else if (age < 0.35) {
                    ctx.fillStyle = `rgba(255,220,100,${alpha})`;
                } else {
                    ctx.fillStyle = `rgba(255,124,32,${alpha})`;
                }
                ctx.fillText(ch, pt.c * CW, pt.r * LINE_H);
            }
        }

        raf = requestAnimationFrame(renderFrame);
    }

    const handleWheel = (e: WheelEvent) => {
        if (!e.ctrlKey) return;
        e.preventDefault();
        e.stopPropagation();
        const factor = e.deltaY > 0 ? 1 / 1.1 : 1.1;
        viewScale = Math.min(S_MAX, Math.max(S_MIN, viewScale * factor));
    };

    const handleMouseDown = (e: MouseEvent) => {
        if (e.button !== 0) return;
        const target = e.target as HTMLElement;
        if (target.closest("#contact-form, input, textarea, button, select, a, label")) return;
        dragging = true;
        mx0 = e.clientX;
        my0 = e.clientY;
        e.preventDefault();
    };

    const handleMouseMove = (e: MouseEvent) => {
        if (!dragging) return;
        panX += e.clientX - mx0;
        panY += e.clientY - my0;
        mx0 = e.clientX;
        my0 = e.clientY;
    };

    const handleMouseUp = (e: MouseEvent) => {
        if (e.button === 0) dragging = false;
    };
    const handleCtxMenu = (e: Event) => {
        if (dragging) e.preventDefault();
    };

    resize();

    img = new Image();
    img.onload = () => {
        raf = requestAnimationFrame(renderFrame);
    };
    img.src = "/blackhole.png";

    window.addEventListener("resize", resize);
    document.addEventListener("wheel", handleWheel, { passive: false });
    document.addEventListener("mousedown", handleMouseDown);
    document.addEventListener("mousemove", handleMouseMove);
    document.addEventListener("mouseup", handleMouseUp);
    document.addEventListener("contextmenu", handleCtxMenu);
</script>

<style>
    #galaxy-canvas {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: 0;
        background: #000;
        pointer-events: auto;
    }
</style>
